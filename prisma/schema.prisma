generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  transcriptions Transcription[]
  settings      UserSettings?
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  whisperModel      String   @default("base")
  language          String   @default("en")
  hotkey            String   @default("Ctrl+Shift+Space")
  autoLaunch        Boolean  @default(false)
  theme             String   @default("system")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Transcription {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioPath     String?
  text          String   @db.Text
  language      String?
  model         String
  duration      Float?
  accuracy      Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model VocabularyEntry {
  id            String   @id @default(cuid())
  word          String
  pronunciation String?
  context       String?
  frequency     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([word])
}

model Analytics {
  id                String   @id @default(cuid())
  date              DateTime @default(now())
  totalTranscriptions Int    @default(0)
  totalDuration     Float    @default(0)
  avgAccuracy       Float?
  activeUsers       Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([date])
}

model DevelopmentTask {
  id                String              @id @default(cuid())
  phase             Int
  taskNumber        Int
  title             String
  description       String              @db.Text
  status            TaskStatus          @default(PENDING)
  priority          TaskPriority        @default(MEDIUM)
  
  // Code tracking
  filesCreated      String[]
  filesModified     String[]
  linesOfCode       Int                 @default(0)
  
  // Verification tracking
  codeWritten       Boolean             @default(false)
  codeVerified      Boolean             @default(false)
  testsWritten      Boolean             @default(false)
  testsPassed       Boolean             @default(false)
  buildSuccessful   Boolean             @default(false)
  
  // Dependencies
  dependsOn         String[]
  blockedBy         String[]
  
  // Metadata
  estimatedHours    Float?
  actualHours       Float?
  startedAt         DateTime?
  completedAt       DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  verifications     TaskVerification[]
  notes             TaskNote[]
  
  @@unique([phase, taskNumber])
  @@index([status])
  @@index([phase])
}

model TaskVerification {
  id                String              @id @default(cuid())
  taskId            String
  task              DevelopmentTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  verificationType  VerificationType
  description       String              @db.Text
  status            VerificationStatus  @default(PENDING)
  
  // Test details
  testCommand       String?
  expectedOutput    String?             @db.Text
  actualOutput      String?             @db.Text
  errorMessage      String?             @db.Text
  
  // Verification results
  passed            Boolean             @default(false)
  verifiedBy        String?
  verifiedAt        DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([taskId])
  @@index([status])
}

model TaskNote {
  id                String              @id @default(cuid())
  taskId            String
  task              DevelopmentTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  content           String              @db.Text
  noteType          NoteType            @default(GENERAL)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([taskId])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  CODE_WRITTEN
  TESTING
  VERIFIED
  COMPLETED
  BLOCKED
  SKIPPED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VerificationType {
  UNIT_TEST
  INTEGRATION_TEST
  BUILD_TEST
  MANUAL_TEST
  CODE_REVIEW
  PERFORMANCE_TEST
  SECURITY_TEST
}

enum VerificationStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  SKIPPED
}

enum NoteType {
  GENERAL
  BUG
  IMPROVEMENT
  BLOCKER
  QUESTION
}
